# ============================================================
# ArthaPatra — environment variable reference
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.
# ============================================================

# ------------------------------------------------------------
# Supabase — public (safe to expose to browser / commit to CI)
# Get these from: Supabase Dashboard -> Settings -> API Keys
# ------------------------------------------------------------

# Project REST URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable key (sb_publishable_xxx) — NOT the service-role key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>

# ------------------------------------------------------------
# Supabase — server-only (never expose to the browser)
# ------------------------------------------------------------

# Service-role (secret) key — bypasses RLS; server-only
# Get from: Supabase Dashboard -> Settings -> API Keys -> Secret key
# DO NOT prefix with NEXT_PUBLIC_ — that would send it to the browser
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-secret-key>

# ------------------------------------------------------------
# SMS provider — server-only (never expose to the browser)
# Only needed when a live SMS provider is enabled in supabase/config.toml.
# For local dev/CI: leave blank — test_otp fixed codes are used instead.
# ------------------------------------------------------------

# Twilio (Option A in config.toml)
# Get from: https://console.twilio.com
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# Textlocal (Option B in config.toml — India DLT-registered)
# Get from: https://www.textlocal.in
# SUPABASE_AUTH_SMS_TEXTLOCAL_SENDER=
# SUPABASE_AUTH_SMS_TEXTLOCAL_API_KEY=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------

# Canonical public URL of the app (used for redirects, OG, etc.)
NEXT_PUBLIC_APP_URL=https://app.arthapatra.in
